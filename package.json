{
  "name": "karyar-website-builder",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "server": "json-server --watch db.json --port 3001 --host 0.0.0.0",
    "client": "vite --port 5173 --host",
    "dev": "concurrently -n api,web -c green,cyan \"npm run server\" \"npm run client\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "json-server": "^0.17.4",
    "vite": "^8.1.1"
  }
}
